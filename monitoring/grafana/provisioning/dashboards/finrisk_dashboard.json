                    "datasource": "Prometheus",
                    "expr": "rate(http_requests_total[5m])",
                    "legendFormat": "{{method}} {{route}} ({{status_code}})",
                    "refId": "A"
                }
            ],
            "title": "HTTP Request Rate (Frontend)",
            "type": "timeseries"
        },
        {
            "datasource": "Prometheus",
